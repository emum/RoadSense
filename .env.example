# RoadSense Environment Variables
# Copy this file to .env and fill in your values.

# Anthropic API key for AI analysis feature
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Admin API key for triggering data refreshes via /api/refresh
# Generate a strong random string (e.g. openssl rand -hex 32)
ADMIN_API_KEY=your_admin_api_key_here

# Server port (default 3001)
PORT=3001

# Frontend URL for CORS (default http://localhost:5173)
FRONTEND_URL=http://localhost:5173
